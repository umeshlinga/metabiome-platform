# ── Database ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=metabiome
POSTGRES_USER=metabiome_user
POSTGRES_PASSWORD=changeme_local

# ── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ENVIRONMENT=development

# ── AWS ───────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_RAW=metabiome-raw-fastq
S3_BUCKET_RESULTS=metabiome-pipeline-results
AWS_BATCH_JOB_QUEUE=metabiome-pipeline-queue
AWS_BATCH_JOB_DEFINITION=metabiome-pipeline-job

# ── Pipeline ──────────────────────────────────────────────
PIPELINE_WORK_DIR=/tmp/nextflow-work
REFERENCE_GENOME_PATH=s3://metabiome-references/GRCh38/genome.fa
KRAKEN2_DB_PATH=s3://metabiome-references/kraken2/standard

# ── Frontend ──────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
