{
  "Comment": "MetaBiome Platform — IAM policies for ECS and Batch roles",

  "ECSTaskExecutionRole": {
    "Description": "Allows ECS tasks to pull images from ECR and write logs to CloudWatch",
    "AssumeRolePolicyDocument": {
      "Version": "2012-10-17",
      "Statement": [{
        "Effect": "Allow",
        "Principal": { "Service": "ecs-tasks.amazonaws.com" },
        "Action": "sts:AssumeRole"
      }]
    },
    "ManagedPolicies": [
      "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
    ]
  },

  "MetaBiomeAPIRole": {
    "Description": "Allows the API container to access S3 and submit Batch jobs",
    "AssumeRolePolicyDocument": {
      "Version": "2012-10-17",
      "Statement": [{
        "Effect": "Allow",
        "Principal": { "Service": "ecs-tasks.amazonaws.com" },
        "Action": "sts:AssumeRole"
      }]
    },
    "InlinePolicy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "S3RawBucketAccess",
          "Effect": "Allow",
          "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket"],
          "Resource": [
            "arn:aws:s3:::metabiome-raw-fastq-*",
            "arn:aws:s3:::metabiome-raw-fastq-*/*"
          ]
        },
        {
          "Sid": "S3ResultsBucketAccess",
          "Effect": "Allow",
          "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket"],
          "Resource": [
            "arn:aws:s3:::metabiome-pipeline-results-*",
            "arn:aws:s3:::metabiome-pipeline-results-*/*"
          ]
        },
        {
          "Sid": "BatchJobSubmission",
          "Effect": "Allow",
          "Action": [
            "batch:SubmitJob",
            "batch:DescribeJobs",
            "batch:TerminateJob",
            "batch:ListJobs"
          ],
          "Resource": "*"
        },
        {
          "Sid": "CloudWatchLogs",
          "Effect": "Allow",
          "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
          "Resource": "arn:aws:logs:*:*:log-group:/metabiome/*"
        }
      ]
    }
  },

  "MetaBiomeBatchJobRole": {
    "Description": "Allows pipeline Batch jobs to read/write S3 and access reference genomes",
    "AssumeRolePolicyDocument": {
      "Version": "2012-10-17",
      "Statement": [{
        "Effect": "Allow",
        "Principal": { "Service": "ecs-tasks.amazonaws.com" },
        "Action": "sts:AssumeRole"
      }]
    },
    "InlinePolicy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "S3PipelineAccess",
          "Effect": "Allow",
          "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket"],
          "Resource": [
            "arn:aws:s3:::metabiome-raw-fastq-*",
            "arn:aws:s3:::metabiome-raw-fastq-*/*",
            "arn:aws:s3:::metabiome-pipeline-results-*",
            "arn:aws:s3:::metabiome-pipeline-results-*/*",
            "arn:aws:s3:::metabiome-references",
            "arn:aws:s3:::metabiome-references/*"
          ]
        },
        {
          "Sid": "CloudWatchLogs",
          "Effect": "Allow",
          "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
          "Resource": "arn:aws:logs:*:*:log-group:/metabiome/pipeline/*"
        }
      ]
    }
  }
}
